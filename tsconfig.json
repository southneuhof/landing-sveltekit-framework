{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "isolatedModules": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": "src",
    "sourceMap": true,
    "strict": false,
    "types": ["svelte"]
  },
  "include": ["src/**/*"],
  "exclude": ["src/**/__tests__/**", "src/**/*.spec.*", "src/**/*.test.*"]
}
